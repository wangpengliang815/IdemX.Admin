# 端口号
VITE_PORT=5666

VITE_BASE=/

# 百度统计（开发环境留空，避免污染线上数据）
VITE_BAIDU_TONGJI_ID=

# 接口地址
VITE_GLOB_API_URL=http://localhost:5000/api/

# 本地开发时邀请链接默认用 localhost；若需模拟线上域名可取消注释：
# VITE_GLOB_SITE_URL=https://www.example.com

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
