VITE_BASE=/

# 百度统计站点 ID（hm.js 参数，留空则不加载）
VITE_BAIDU_TONGJI_ID=9043aa32f1d8311080f6a055ff549f64

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置none, brotli, gzip
VITE_COMPRESS=none

# 是否开启PWA
VITE_PWA=false

# vue-router 的模式VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
