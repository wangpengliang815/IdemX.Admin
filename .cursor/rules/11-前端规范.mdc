# 前端规范

## 硬约束

| 规则 | 说明 |
|------|------|
| 雪花 ID 全链路 `string` | 禁止 `: number` / `Number(id)` / `parseInt(id)` |
| 图标用 Iconify | 禁止 `@ant-design/icons-vue` |
| 确认操作用 `CellOperation.popconfirm` | 禁止 `Modal.confirm` |
| 成功提示 `message.success(res.msg)` | 失败 `message.error(res.msg)` |
| 成功路径信任契约 | 禁止 `?? []` / `res.data ?? []` 等防御兜底 |

## API 文件模板

锚文件：`api/system/user.ts`、`api/contract/contract.ts`

```typescript
import type { ApiResponse } from '#/api/request';
import { requestClient } from '#/api/request';

export interface XxxResp {
  id: string;
  // ...
}

export interface XxxReq { /* ... */ }

export interface XxxPageQueryReq {
  page: number;
  pageSize: number;
  // 筛选字段...
}

export function getPageListApi(params?: XxxPageQueryReq): Promise<ApiResponse<XxxResp[]>> {
  return requestClient.post('/xxx/getPageList', params ?? {});
}

export function getByIdApi(id: string): Promise<ApiResponse<XxxResp>> {
  return requestClient.get(`/xxx/getById/${id}`);
}

export function createApi(data: XxxReq): Promise<ApiResponse<void>> {
  return requestClient.post('/xxx/create', data);
}

export function editApi(id: string, data: XxxReq): Promise<ApiResponse<void>> {
  return requestClient.post(`/xxx/edit/${id}`, data);
}

export function delApi(id: string): Promise<ApiResponse<void>> {
  return requestClient.post(`/xxx/del/${id}`);
}
```

## 列表页模板 (index.vue)

锚文件：`views/system/user/index.vue`

```vue
<script lang="ts" setup>
import { useVbenDrawer } from '@vben/common-ui';
import { message } from 'ant-design-vue';
import { useVbenVxeGrid } from '#/adapter/vxe-table';
import XxxForm from './modules/form.vue';
import { useGridFormSchema, useTableColumns } from './data';

const [FormDrawer, formDrawerApi] = useVbenDrawer({
  connectedComponent: XxxForm,
  destroyOnClose: true,
});

const [Grid, gridApi] = useVbenVxeGrid({
  formOptions: {
    schema: useGridFormSchema(() => gridApi.query()),
    submitOnChange: false,
    showCollapseButton: false,
  },
  gridOptions: {
    columns: useTableColumns(onActionClick),
    height: 'auto',
    keepSource: true,
    pagerConfig: { pageSize: 30, pageSizes: [30, 50, 100] },
    proxyConfig: {
      ajax: {
        query: async ({ page }, formValues) => {
          const res = await xxxApi.getPageListApi({ page: page.currentPage, pageSize: page.pageSize, ...formValues });
          if (res.code !== 0) { message.error(res.msg); return { data: [], total: 0 }; }
          return { data: res.data!, total: res.total! };
        },
      },
      response: { result: 'data', total: 'total' },
    },
    rowConfig: { keyField: 'id' },
    toolbarConfig: { custom: true, export: false, refresh: true, zoom: true },
  },
});

async function onActionClick({ code, row }) {
  switch (code) {
    case 'edit': { formDrawerApi.setData(row).open(); break; }
    case 'delete': {
      const res = await xxxApi.delApi(row.id);
      if (res.code === 0) { message.success(res.msg); gridApi.query(); }
      else { message.error(res.msg); }
      break;
    }
  }
}
</script>
```

## data.ts 模板

锚文件：`views/system/user/data.ts`

导出三个工厂函数：

| 函数 | 用途 |
|------|------|
| `useTableColumns(onActionClick)` | VxeTable 列 + CellOperation 操作列 |
| `useGridFormSchema(onSearch?)` | 列表页顶部搜索表单 |
| `useFormSchema(...)` | Drawer 编辑表单（zod 校验） |

操作列固定写法：
```typescript
{
  field: 'operation', fixed: 'right', title: '操作',
  cellRender: {
    name: 'CellOperation',
    attrs: { nameField: 'name', onClick: onActionClick },
    options: [
      { code: 'edit', text: '编辑', color: 'blue' },
      { code: 'delete', text: '删除', color: 'red', popconfirm: {
        title: '确定删除', description: '删除后无法恢复，是否继续？',
        okText: '确定', cancelText: '取消',
      }},
    ],
  },
}
```

枚举列用 `cellRender: { name: 'CellTag', options: useEnumOptions('XxxStatus', { 0: 'blue', 1: 'green' }).value }`

## Drawer 表单模板 (modules/form.vue)

锚文件：`views/system/user/modules/form.vue`

```vue
<script lang="ts" setup>
import { useVbenDrawer } from '@vben/common-ui';
import { message } from 'ant-design-vue';
import { useVbenForm } from '#/adapter/form';

const emit = defineEmits<{ success: [] }>();
const formData = ref<XxxResp | undefined>();

const [Form, formApi] = useVbenForm(reactive({
  layout: 'horizontal',
  labelWidth: 120,
  schema: computed(() => useFormSchema(!!formData.value?.id)),
  showDefaultActions: false,
}));

const [Drawer, drawerApi] = useVbenDrawer({
  onConfirm: handleSubmit,
  onOpenChange: async (isOpen) => {
    if (!isOpen) return;
    const raw = drawerApi.getData() as XxxResp | undefined;
    formData.value = raw;
    await formApi.setValues(raw ? buildEditValues(raw) : getDefaultReq());
  },
});

async function handleSubmit() {
  const { valid } = await formApi.validate();
  if (!valid) return;
  drawerApi.lock();
  try {
    const values = await formApi.getValues();
    const res = formData.value?.id
      ? await xxxApi.editApi(formData.value.id, values)
      : await xxxApi.createApi(values);
    if (res.code === 0) { message.success(res.msg); drawerApi.close(); emit('success'); }
    else { message.error(res.msg); }
  } finally { drawerApi.unlock(); }
}
</script>

<template>
  <Drawer :title="formData?.id ? '编辑' : '新增'">
    <Form />
  </Drawer>
</template>
```
